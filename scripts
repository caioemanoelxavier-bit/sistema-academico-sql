
USE sistema_academico;

-- MÓDULO RH
CREATE TABLE tb_funcionario (
    pk_funcionario INT AUTO_INCREMENT PRIMARY KEY,
    fk_cpf CHAR(11) UNIQUE NOT NULL,
    nome VARCHAR(150) NOT NULL,
    email VARCHAR(150) UNIQUE NOT NULL,
    salario DECIMAL(10,2) NOT NULL,
    status ENUM('ativo', 'inativo', 'afastado', 'demitido') DEFAULT 'ativo' NOT NULL
) ENGINE=InnoDB;

CREATE TABLE tb_professor (
    pk_professor INT AUTO_INCREMENT PRIMARY KEY,
    fk_funcionario INT UNIQUE NOT NULL,
    titulacao ENUM('Graduado', 'Especialista', 'Mestre', 'Doutor') NOT NULL,
    area_atuacao VARCHAR(100) NOT NULL,
    CONSTRAINT fk_prof_func FOREIGN KEY (fk_funcionario) REFERENCES tb_funcionario(pk_funcionario)
) ENGINE=InnoDB;

-- MÓDULO ACADÊMICO
CREATE TABLE tb_aluno (
    pk_rgm INT AUTO_INCREMENT PRIMARY KEY,
    fk_cpf CHAR(11) UNIQUE NOT NULL,
    status ENUM('ativo', 'trancado', 'formado', 'evadido') DEFAULT 'ativo' NOT NULL,
    dt_inscricao TIMESTAMP DEFAULT NOW()
) ENGINE=InnoDB;

CREATE TABLE tb_curso (
    pk_curso INT AUTO_INCREMENT PRIMARY KEY,
    fk_professor INT NOT NULL,
    nome VARCHAR(150) UNIQUE NOT NULL,
    carga_horaria INT NOT NULL,
    CONSTRAINT fk_curso_prof FOREIGN KEY (fk_professor) REFERENCES tb_professor(pk_professor)
) ENGINE=InnoDB;

CREATE TABLE tb_disciplina (
    pk_disciplina INT AUTO_INCREMENT PRIMARY KEY,
    fk_curso INT NOT NULL,
    nome VARCHAR(150) NOT NULL,
    carga_horaria INT NOT NULL,
    CONSTRAINT fk_disc_curso FOREIGN KEY (fk_curso) REFERENCES tb_curso(pk_curso)
) ENGINE=InnoDB;

CREATE TABLE tb_nota (
    pk_nota INT AUTO_INCREMENT PRIMARY KEY,
    fk_rgm INT NOT NULL,
    fk_disciplina INT NOT NULL,
    valor DECIMAL(4,2) NOT NULL CHECK (valor BETWEEN 0 AND 10),
    CONSTRAINT fk_nota_aluno FOREIGN KEY (fk_rgm) REFERENCES tb_aluno(pk_rgm),
    CONSTRAINT fk_nota_disc FOREIGN KEY (fk_disciplina) REFERENCES tb_disciplina(pk_disciplina)
) ENGINE=InnoDB;

-- MÓDULO FINANCEIRO
CREATE TABLE tb_mensalidade (
    pk_mensalidade INT AUTO_INCREMENT PRIMARY KEY,
    fk_rgm INT NOT NULL,
    vlr_liquido DECIMAL(10,2) NOT NULL,
    dt_vencimento DATE NOT NULL,
    status ENUM('pendente', 'pago', 'atrasado', 'cancelado') DEFAULT 'pendente' NOT NULL,
    CONSTRAINT fk_mens_aluno FOREIGN KEY (fk_rgm) REFERENCES tb_aluno(pk_rgm)
) ENGINE=InnoDB;

CREATE TABLE tb_pagamento (
    pk_pagamento INT AUTO_INCREMENT PRIMARY KEY,
    fk_mensalidade INT NOT NULL,
    dt_pagamento DATE NOT NULL,
    vlr_pago DECIMAL(10,2) NOT NULL,
    forma ENUM('PIX', 'Boleto', 'Cartão', 'Dinheiro') NOT NULL,
    CONSTRAINT fk_pag_mens FOREIGN KEY (fk_mensalidade) REFERENCES tb_mensalidade(pk_mensalidade)
) ENGINE=InnoDB;
